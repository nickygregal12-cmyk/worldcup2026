{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/block-git-add-all.mjs\"",
            "statusMessage": "Checking git add scope (CLAUDE.md §0.4)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/block-wc26-production.mjs\"",
            "statusMessage": "Checking for WC26 production ref (CLAUDE.md §2)",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

# Browser-safe Vite variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=staging
VITE_TOURNAMENT_ID=euro-2028-staging
VITE_TOURNAMENT_NAME=Euro 2028 Predictor
VITE_TOURNAMENT_SHORT_NAME=EURO 2028
VITE_TOURNAMENT_YEAR=2028
VITE_ENABLE_TIME_TRAVEL=true

# Inactive legacy timing variables retained for quarantined WC26 modules.
# Do not use these to drive the Stage 2 Euro foundation.
VITE_PREDICTION_LOCK_AT=
VITE_TOURNAMENT_START_AT=
VITE_GROUP_STAGE_END_AT=
VITE_KO_PREDICTOR_OPEN_AT=
VITE_TOURNAMENT_END_AT=

# Netlify server-only variables. Never prefix secrets with VITE_.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ADMIN_FUNCTION_SECRET=
ENABLE_SCORE_SYNC=false

# Stage 14 optional observability. The DSN is a browser public key, not a service-role secret.
VITE_OBSERVABILITY_ENABLED=true
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=staging

# Netlify server-only Sentry variables. Configure in the Netlify UI; never commit values.
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
